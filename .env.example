# Copy to .env for local development with `pnpm dev` (Node runtime).
# For `pnpm preview` / `pnpm deploy` (Cloudflare Workers runtime), the same
# values must live in .dev.vars instead — wrangler does not read .env.
# In production, set them as Worker secrets: wrangler secret put <NAME>
#
# Supabase project URL and publishable (anon) key (Project Settings > API).
# Supabase is opt-in: if unset, the app runs fully local/anonymous (no cloud sync).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=

# Master key (KEK) that wraps every per-user data-encryption key. It must be
# 32 random bytes in base64 — generate one with: openssl rand -base64 32
# Losing it makes all encrypted cloud rows unrecoverable: back it up in a
# password manager. If it is unset, the app syncs in plaintext (crypto_version 0).
ENCRYPTION_MASTER_KEY=
